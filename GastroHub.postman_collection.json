    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Cadastrar Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('user_id', json.id);",
                  "if (json.address && json.address.length && json.address[0].id) pm.collectionVariables.set('address_id', json.address[0].id);",
                  "pm.test('Cadastra usuario cliente', function () { pm.expect(json.role).to.eql('ROLE_CLIENTE'); pm.expect(json.senha).to.be.undefined; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"{{client_name}}\",\n  \"email\": \"{{client_email}}\",\n  \"login\": \"{{client_login}}\",\n  \"senha\": \"123456\",\n  \"role\": \"ROLE_CLIENTE\",\n  \"address\": [\n    {\n      \"cep\": \"01001-000\",\n      \"rua\": \"Praca da Se\",\n      \"numero\": \"100\",\n      \"cidade\": \"Sao Paulo\",\n      \"estado\": \"SP\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Cadastrar Dono Restaurante",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('owner_id', json.id);",
                  "pm.test('Cadastra dono de restaurante', function () { pm.expect(json.role).to.eql('ROLE_DONO_RESTAURANTE'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"{{owner_name}}\",\n  \"email\": \"{{owner_email}}\",\n  \"login\": \"{{owner_login}}\",\n  \"senha\": \"123456\",\n  \"role\": \"ROLE_DONO_RESTAURANTE\",\n  \"address\": [\n    {\n      \"cep\": \"01310-100\",\n      \"rua\": \"Avenida Paulista\",\n      \"numero\": \"1000\",\n      \"cidade\": \"Sao Paulo\",\n      \"estado\": \"SP\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/users"
          }
